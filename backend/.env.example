APP_NAME=知枢星图
APP_ENV=development
DEBUG=true
SECRET_KEY=your-secret-key-here-change-in-production

DATABASE_URL=sqlite:///./data/knowledge.db

JWT_SECRET_KEY=your-jwt-secret-key-here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_DAYS=7

OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-3.5-turbo

DASHSCOPE_API_KEY=your-dashscope-api-key
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v3

EMBEDDING_MODEL=all-MiniLM-L6-v2

FAISS_INDEX_PATH=./data/faiss_index

# LangChain 功能开关（渐进式迁移）
# 逐步开启以验证 LangChain 实现，默认全部关闭使用原有实现
USE_LANGCHAIN_EMBEDDINGS=false
USE_LANGCHAIN_VECTORSTORE=false
USE_LANGCHAIN_PROMPT=false
USE_LANGCHAIN_RAG=false
USE_LANGCHAIN_CHAT=false
USE_LANGCHAIN_SKILL=false
